#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
TEMP_ROOT=$(mktemp -d "${TMPDIR:-/tmp}/swiftshare-doctor.XXXXXX")
trap 'rm -rf "$TEMP_ROOT"' EXIT INT TERM

FAKE_JDK="$TEMP_ROOT/jdk"
FAKE_SDK="$TEMP_ROOT/sdk"
mkdir -p "$FAKE_JDK/bin" "$FAKE_SDK/platforms/android-36.1"

printf '%s\n' '#!/bin/sh' 'printf '\''openjdk version "17-test"\n'\'' >&2' > "$FAKE_JDK/bin/java"
chmod +x "$FAKE_JDK/bin/java"

output=$(JAVA_HOME="$FAKE_JDK" SWIFTSHARE_ANDROID_SDK="$FAKE_SDK" "$ROOT/scripts/doctor" android 2>&1)
printf '%s\n' "$output" | grep -q "ok: Android SDK at $FAKE_SDK"

set +e
missing_output=$(JAVA_HOME="$FAKE_JDK" SWIFTSHARE_ANDROID_SDK="$TEMP_ROOT/missing" "$ROOT/scripts/doctor" android 2>&1)
missing_exit=$?
set -e

[ "$missing_exit" -ne 0 ]
printf '%s\n' "$missing_output" | grep -q "Android SDK is unavailable at $TEMP_ROOT/missing"

printf 'doctor regression tests: passed\n'
